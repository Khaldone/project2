<linker>
  <!-- Preserve all types in our project assemblies so IL2CPP doesn't strip
       constructors that VContainer resolves via reflection at runtime. -->
  <assembly fullname="CoreDomain" preserve="all" />
  <assembly fullname="Infrastructure" preserve="all" />
  <assembly fullname="Presentation" preserve="all" />
  <assembly fullname="Bootstrapper" preserve="all" />

  <!-- Fallback: if any classes live outside asmdef boundaries -->
  <assembly fullname="Assembly-CSharp" preserve="all" />

  <!-- VContainer internals need reflection access -->
  <assembly fullname="VContainer" preserve="all" />
  <assembly fullname="VContainer.Unity" preserve="all" />

  <!-- UniTask -->
  <assembly fullname="UniTask" preserve="all" />

  <!-- CBS SDK -->
  <assembly fullname="CBS" preserve="all" />

  <!-- PlayFab SDK -->
  <assembly fullname="PlayFabSDK" preserve="all" />
  <assembly fullname="PlayFabSharedSettings" preserve="all" />

  <!-- Photon Fusion -->
  <assembly fullname="Fusion.Runtime" preserve="all" />
</linker>
