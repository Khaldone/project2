# Ignore everything by default
*

# Allow the specific root directories (so Git can traverse them)
!_Project/
!CBS/
!CBS_External/
!Mobile Monetization Pro/
!Plugins/

# Allow .gitignore itself
!.gitignore

# Allow all subdirectories inside the whitelisted folders to be traversed
!_Project/**/
!CBS/**/
!CBS_External/**/
!Mobile Monetization Pro/**/
!Plugins/**/

# Allow whitelisted file extensions inside the traversed folders
!_Project/**/*.cs
!_Project/**/*.json
!_Project/**/*.txt
!_Project/**/*.xml
!_Project/**/*.yaml
!_Project/**/*.asmdef

!CBS/**/*.cs
!CBS/**/*.json
!CBS/**/*.txt
!CBS/**/*.xml
!CBS/**/*.yaml

!CBS_External/**/*.cs
!CBS_External/**/*.json
!CBS_External/**/*.txt
!CBS_External/**/*.xml
!CBS_External/**/*.yaml

!Mobile Monetization Pro/**/*.cs
!Mobile Monetization Pro/**/*.json
!Mobile Monetization Pro/**/*.txt
!Mobile Monetization Pro/**/*.xml
!Mobile Monetization Pro/**/*.yaml

!Plugins/Android/AndroidManifest.xml

